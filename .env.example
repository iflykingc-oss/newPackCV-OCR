# ============================================================
# PackCV-OCR 生产环境配置
# 复制为 .env 并填入实际值
# ============================================================

# 基础
ENV=production
APP_VERSION=7.0.0

# API
API_PORT=9001
API_WORKERS=4
API_BASE_URL=https://api.packcv.com

# Redis
REDIS_URL=redis://packcv-redis:6379/0
REDIS_PASSWORD=change-me-strong-password

# PostgreSQL
POSTGRES_HOST=packcv-postgres
POSTGRES_PORT=5432
POSTGRES_DB=packcv
POSTGRES_USER=packcv
POSTGRES_PASSWORD=change-me-strong-password

# 域名
DOMAIN=api.packcv.com

# SSL
LETSENCRYPT_EMAIL=ops@packcv.com

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me

# 告警
ALERT_EMAIL=ops@packcv.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@packcv.com
SMTP_PASSWORD=change-me

# LLM API Keys (从技能文档获取，禁止编造)
DOUBAO_API_KEY=your-doubao-api-key
KIMI_API_KEY=your-kimi-api-key
QWEN_API_KEY=your-qwen-api-key

# LangSmith (可选)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=packcv-prod
LANGCHAIN_TRACING_V2=true

# 业务参数
RATE_LIMIT_DEFAULT_RPM=60
WORKFLOW_TIMEOUT_SECONDS=120
ENABLE_DEMO_DATA=false
